<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <!--
    Gazebo Harmonic (gz-sim 8) plugins for the MiR robot.
    Included only by mir_sim.urdf.xacro for simulation builds.
  -->

  <xacro:macro name="mir_gz_plugins" params="prefix mir_type">

    <!-- ============ Diff-drive controller ============ -->
    <xacro:if value="${mir_type == 'mir_100'}">
      <xacro:property name="gz_wheel_separation" value="0.445208" />
      <xacro:property name="gz_wheel_radius"     value="0.0625" />
    </xacro:if>
    <xacro:if value="${mir_type == 'mir_250'}">
      <xacro:property name="gz_wheel_separation" value="0.403" />
      <xacro:property name="gz_wheel_radius"     value="0.100" />
    </xacro:if>

    <gazebo>
      <plugin filename="gz-sim-diff-drive-system"
              name="gz::sim::systems::DiffDrive">
        <left_joint>${prefix}left_wheel_joint</left_joint>
        <right_joint>${prefix}right_wheel_joint</right_joint>
        <wheel_separation>${gz_wheel_separation}</wheel_separation>
        <wheel_radius>${gz_wheel_radius}</wheel_radius>
        <max_linear_acceleration>2.0</max_linear_acceleration>
        <max_angular_acceleration>2.5</max_angular_acceleration>
        <odom_publish_frequency>41.2</odom_publish_frequency>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>${prefix}base_footprint</child_frame_id>
      </plugin>
    </gazebo>

    <!-- ============ Joint state publisher ============ -->
    <gazebo>
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <topic>joint_states</topic>
      </plugin>
    </gazebo>

    <!-- ============ Front laser (SICK S300) ============ -->
    <gazebo reference="${prefix}front_laser_link">
      <sensor name="front_laser" type="gpu_lidar">
        <gz_frame_id>${prefix}front_laser_link</gz_frame_id>
        <topic>f_scan</topic>
        <update_rate>12.5</update_rate>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>541</samples>
              <resolution>1</resolution>
              <min_angle>-2.2</min_angle>
              <max_angle>2.2</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>15.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.003</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>

    <!-- ============ Back laser (SICK S300) ============ -->
    <gazebo reference="${prefix}back_laser_link">
      <sensor name="back_laser" type="gpu_lidar">
        <gz_frame_id>${prefix}back_laser_link</gz_frame_id>
        <topic>b_scan</topic>
        <update_rate>12.5</update_rate>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <lidar>
          <scan>
            <horizontal>
              <samples>541</samples>
              <resolution>1</resolution>
              <min_angle>-2.2</min_angle>
              <max_angle>2.2</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>15.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.003</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>

    <!-- ============ IMU ============ -->
    <gazebo reference="${prefix}imu_link">
      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>${prefix}imu_frame</gz_frame_id>
        <topic>imu_data</topic>
        <update_rate>50.0</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </gazebo>

    <!-- ============ Wheel friction ============ -->
    <gazebo reference="${prefix}left_wheel_link">
      <mu1>200</mu1>
      <mu2>200</mu2>
    </gazebo>
    <gazebo reference="${prefix}right_wheel_link">
      <mu1>200</mu1>
      <mu2>200</mu2>
    </gazebo>
    <gazebo reference="${prefix}fl_caster_wheel_link">
      <mu1>1</mu1>
      <mu2>1</mu2>
    </gazebo>
    <gazebo reference="${prefix}fr_caster_wheel_link">
      <mu1>1</mu1>
      <mu2>1</mu2>
    </gazebo>
    <gazebo reference="${prefix}bl_caster_wheel_link">
      <mu1>1</mu1>
      <mu2>1</mu2>
    </gazebo>
    <gazebo reference="${prefix}br_caster_wheel_link">
      <mu1>1</mu1>
      <mu2>1</mu2>
    </gazebo>

  </xacro:macro>
</robot>
